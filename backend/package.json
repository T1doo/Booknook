{
  "name": "booknook-backend",
  "version": "1.0.0",
  "description": "BookNook · 暖书阁图书销售管理系统 · 后端 (Express + Prisma)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
