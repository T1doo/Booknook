# =============================================================================
# BookNook Backend · 环境变量示例
# 复制本文件为 .env 后,按本机情况修改
# =============================================================================

# 服务端口
PORT=4000

# CORS 允许的前端来源 (逗号分隔)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT 配置
# JWT_SECRET 必须 >= 32 字符且不能包含 please-change / do-not-use / example 字样,
# 否则后端启动会被拒绝. 推荐执行下面这条命令生成:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<RUN-THE-COMMAND-ABOVE-AND-PASTE-HERE>
JWT_EXPIRES_IN=7d
COOKIE_NAME=booknook_token

# PostgreSQL 连接串 (Prisma 用)
# 格式: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://postgres:060425@127.0.0.1:5432/booknook?schema=public

# 日志级别 (silent / fatal / error / warn / info / debug / trace)
LOG_LEVEL=info

# 节点环境
NODE_ENV=development
